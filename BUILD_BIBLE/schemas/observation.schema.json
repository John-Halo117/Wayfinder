{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb:schema:observation",
  "title": "Build Bible Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "observed_scope_ids",
    "observer",
    "observed_at",
    "method",
    "description",
    "evidence",
    "uncertainty",
    "affected_records"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^bb:observation:[a-z0-9-]+(?:/[a-z0-9-]+)*$"
    },
    "observed_scope_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "observer": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "uncertainty": {
      "type": "string",
      "minLength": 1
    },
    "affected_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

