{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bb:schema:generated-artifact-manifest",
  "title": "Build Bible Generated Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_path",
    "artifact_type",
    "source_scope_ids",
    "source_revisions",
    "generator",
    "generator_version",
    "generated_at",
    "validation_status"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^bb:artifact:[a-z0-9-]+(?:/[a-z0-9-]+)*$"
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "enum": ["cad", "bim", "diagram", "bom", "material-takeoff", "construction-phase", "inspection-checklist", "maintenance-schedule", "home-assistant-config", "esphome-config", "network-config", "documentation"]
    },
    "source_scope_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_revisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "generator": {
      "type": "string",
      "minLength": 1
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "validation_status": {
      "enum": ["passed", "failed", "not-run"]
    }
  }
}

