# Execution Runtime selects the bounded execution environment. It does not
# select truth, memory, ARK evidence, inventory, bearings, or constitutional
# ownership.
EXECUTION_RUNTIME=odysseus

# Odysseus remains optional and reversible beneath the runtime provider.
ODYSSEUS_ENABLED=true
ODYSSEUS_BASE_URL=http://127.0.0.1:7000
ODYSSEUS_TIMEOUT_SECONDS=5

