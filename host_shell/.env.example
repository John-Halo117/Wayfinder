# Host Shell selects the interaction runtime provider. It does not select truth,
# memory, ARK evidence, inventory, bearings, or constitutional ownership.
HOST_SHELL=odysseus

# Odysseus remains optional and reversible beneath the Host Shell provider.
ODYSSEUS_ENABLED=true
ODYSSEUS_BASE_URL=http://127.0.0.1:7000
ODYSSEUS_TIMEOUT_SECONDS=5
