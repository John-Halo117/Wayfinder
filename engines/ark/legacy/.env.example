# .env.example - Complete wiring reference
# Copy this to .env and update all values
# ALL VARIABLES BELOW ARE USED BY: docker-compose.yml, traefik/traefik.yml, authelia/configuration.yml

###############################################################################
# DOMAIN & TLS (WIRED: Used everywhere)
###############################################################################
# Primary domain - USED IN:
#   - docker-compose.yml: traefik labels, authelia labels, navidrome labels
#   - authelia/configuration.yml: access_control rules (${DOMAIN})
DOMAIN=music.example.com

# Top-level domain (for session cookies) - USED IN:
#   - authelia/configuration.yml: session.domain, cookies.domain
# MUST BE PARENT DOMAIN OF DOMAIN (e.g., if DOMAIN=music.example.com, TOP_LEVEL_DOMAIN=example.com)
TOP_LEVEL_DOMAIN=example.com

# Email for Let's Encrypt certificate expiration notifications - USED IN:
#   - traefik/traefik.yml: certificateResolvers.letsencrypt.acme.email (hardcoded as admin@example.com; change in file)
LETSENCRYPT_EMAIL=admin@example.com

# Let's Encrypt environment (production or staging)
#   - traefik/traefik.yml: certificateResolvers.letsencrypt.acme.server (hardcoded as production; change in file)
LETSENCRYPT_ENV=production

###############################################################################
# TIMEZONE (WIRED: Passed to all services)
###############################################################################
# Used in: docker-compose.yml environment: TZ=${TZ:-UTC}
TZ=UTC

###############################################################################
# REDIS (Session store for Authelia) - WIRED TO AUTHELIA
###############################################################################
# Redis password - USED IN:
#   - docker-compose.yml: redis command (--requirepass ${REDIS_PASSWORD})
#   - docker-compose.yml: authelia environment (REDIS_PASSWORD)
#   - authelia/configuration.yml: session.redis.password (${REDIS_PASSWORD})
# CRITICAL: Change from default; generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_BYTES_BASE64

###############################################################################
# AUTHELIA - WIRED TO TRAEFIK & NAVIDROME
###############################################################################
# Log level - USED IN:
#   - docker-compose.yml: authelia environment (AUTHELIA_LOG_LEVEL)
AUTHELIA_LOG_LEVEL=info

# TOTP secret (for 2FA setup) - USED IN:
#   - docker-compose.yml: authelia environment (AUTHELIA_TOTP_SECRET)
#   - authelia/configuration.yml: totp.secret (${AUTHELIA_TOTP_SECRET})
# CRITICAL: Change from default; generate: openssl rand -base64 32
AUTHELIA_TOTP_SECRET=CHANGE_ME_TOTP_SECRET_32_BYTES_BASE64

###############################################################################
# TRAEFIK - WIRED TO ALL SERVICES
###############################################################################
# Traefik log level - USED IN:
#   - docker-compose.yml: traefik environment (TRAEFIK_LOG_LEVEL)
#   - traefik/traefik.yml: log.level (hardcoded as info; change in file)
TRAEFIK_LOG_LEVEL=info

# Traefik dashboard port - USED IN:
#   - docker-compose.yml: traefik ports (${TRAEFIK_DASHBOARD_PORT}:8080)
TRAEFIK_DASHBOARD_PORT=8080

# Traefik dashboard address - USED IN:
#   - traefik/traefik.yml: entryPoints.traefik.address (hardcoded as :8080; change in file)
TRAEFIK_DASHBOARD_ADDRESS=:8080

###############################################################################
# NAVIDROME - WIRED TO MUSIC LIBRARY
###############################################################################
# Music library path (READ-ONLY bind mount) - USED IN:
#   - docker-compose.yml: navidrome volumes (${MUSIC_PATH}:/music:ro)
# Path MUST exist on host; contains *.mp3, *.flac, etc.
MUSIC_PATH=/srv/navidrome/music

# Navidrome data path (READ-WRITE persistent) - USED IN:
#   - docker-compose.yml: navidrome volumes (${DATA_PATH}:/data)
# Path MUST exist on host; contains navidrome.db, cache
DATA_PATH=/srv/navidrome/data

# Navidrome scan interval (seconds) - USED IN:
#   - docker-compose.yml: navidrome environment (ND_SCANINTERVAL)
NAVIDROME_SCANINTERVAL=3600

# Enable MP3 transcoding - USED IN:
#   - docker-compose.yml: navidrome environment (ND_TRANSCODEMP3)
NAVIDROME_TRANSCODE_MP3=true

###############################################################################
# WIRING VALIDATION CHECKLIST
###############################################################################
# After updating .env, verify:
#
# [ ] DOMAIN matches DNS A record
# [ ] TOP_LEVEL_DOMAIN is parent of DOMAIN (e.g., DOMAIN=music.example.com, TOP_LEVEL_DOMAIN=example.com)
# [ ] REDIS_PASSWORD is 32+ bytes (run: openssl rand -base64 32)
# [ ] AUTHELIA_TOTP_SECRET is 32+ bytes (run: openssl rand -base64 32)
# [ ] MUSIC_PATH exists and is readable (run: ls -l ${MUSIC_PATH})
# [ ] DATA_PATH exists and is writable (run: mkdir -p ${DATA_PATH})
# [ ] LETSENCRYPT_EMAIL is valid
# [ ] All hardcoded values in config files match .env:
#     - traefik/traefik.yml: email, server (production/staging)
#     - traefik/dynamic.yml: accessControlAllowOriginList, cors allowedOrigins
#     - authelia/configuration.yml: session.domain, cookies.domain, access_control rules
#
# WIRING FAILS IF:
# - TOP_LEVEL_DOMAIN doesn't match DOMAIN parent domain
# - MUSIC_PATH/DATA_PATH don't exist or not readable/writable
# - REDIS_PASSWORD not passed to authelia (check docker-compose.yml env)
# - DNS doesn't resolve DOMAIN to server IP
