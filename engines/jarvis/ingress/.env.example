# ═══════════════════════════════════════════════════════════════════
#  Jarvis – Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# ─────────────────────────────────────────────────────────────────
#  ARK "10 Rules"
# ─────────────────────────────────────────────────────────────────
#  Every service, emitter, and integration in this stack MUST
#  respect these rules. They are non-negotiable.
#
#   1. No unbounded feedback loops (automation, network, control).
#   2. All processes are time + resource capped.
#   3. All resources are pre-budgeted.
#   4. Systems are modular and small.
#   5. Every subsystem asserts health continuously.
#   6. State is local, not global.
#   7. Every action returns a verifiable result.
#   8. Flows are linear, observable, debuggable.
#   9. Interfaces are strict and minimal.
#  10. Any anomaly → immediate visibility or fail-safe.
#
# ─────────────────────────────────────────────────────────────────
#
#  QUICK START
#  ───────────
#  Step 1 — Copy this file:
#
#      cp .env.example .env
#
#  Step 2 — Open .env in your editor and fill in every variable
#           marked [REQUIRED]. Leave [OPTIONAL] ones alone unless
#           you know you need to change them.
#
#  Step 3 — Start the stack:
#
#      docker compose up -d
#
#  That's it. If something isn't working, scroll down to the
#  TROUBLESHOOTING section at the bottom of this file.
#
# ─────────────────────────────────────────────────────────────────
#  ⚠  WARNINGS
# ─────────────────────────────────────────────────────────────────
#  • NEVER commit .env — it is already in .gitignore.
#  • NEVER share your .env file with anyone.
#  • NEVER put quotes around the values. Write it like this:
#        HA_TOKEN=abc123
#    NOT like this:
#        HA_TOKEN="abc123"   ← WRONG
#        HA_TOKEN='abc123'   ← WRONG
#  • NO spaces around the = sign:
#        HA_TOKEN=abc123     ← correct
#        HA_TOKEN = abc123   ← WRONG
#  • NO trailing spaces or invisible characters after the value.
#  • If a secret is ever exposed in logs, commits, or error output,
#    rotate (regenerate) it IMMEDIATELY.
#
# ─────────────────────────────────────────────────────────────────
#  LEGEND
# ─────────────────────────────────────────────────────────────────
#  [REQUIRED]  → The service WILL NOT start without this value.
#  [OPTIONAL]  → Has a sensible default; only change if needed.
#  Example:    → Shows exactly what a valid value looks like.
# ═══════════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────────┐
# │  COMPOSIO BRIDGE                                                │
# └─────────────────────────────────────────────────────────────────┘
# What:     API key for the Composio integration layer.
# How:      1. Go to https://app.composio.dev/settings
#           2. Click "API Keys" in the sidebar.
#           3. Click "Create API Key".
#           4. Name it "Jarvis" so you can identify it later.
#           5. Copy the key and paste it below.
# Scope:    Use a key with the minimum permissions your workflows need.
# Example:  COMPOSIO_API_KEY=csk_live_abc123def456ghi789
# [REQUIRED]
COMPOSIO_API_KEY=


# ┌─────────────────────────────────────────────────────────────────┐
# │  HOME ASSISTANT                                                 │
# └─────────────────────────────────────────────────────────────────┘
# What:     Long-lived access token for the Home Assistant API.
# How:      1. Open your Home Assistant instance in a browser.
#           2. Click your profile picture (bottom-left).
#           3. Scroll to "Long-Lived Access Tokens" at the very bottom.
#           4. Click "Create Token".
#           5. Name it "Jarvis".
#           6. Copy the token — you will only see it once!
# Scope:    Create a DEDICATED token for Jarvis. Do NOT reuse your
#           personal token. Revoke and regenerate if compromised.
# Example:  HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOi...
# [REQUIRED]
HA_TOKEN=


# ┌─────────────────────────────────────────────────────────────────┐
# │  JELLYFIN                                                       │
# └─────────────────────────────────────────────────────────────────┘
# What:     API token for the Jellyfin media server.
# How:      1. Open Jellyfin in a browser.
#           2. Go to Dashboard → API Keys  (Admin → Advanced → API Keys).
#           3. Click the "+" button to create a new key.
#           4. Name it "Jarvis".
#           5. Copy the key and paste it below.
# Example:  JELLYFIN_TOKEN=a1b2c3d4e5f64a7b8c9d0e1f2a3b4c5d
# [REQUIRED]
JELLYFIN_TOKEN=

# What:     The user ID whose media activity the emitter tracks.
# How:      1. Open Jellyfin in a browser.
#           2. Go to Dashboard → Users.
#           3. Click on the user you want to track.
#           4. Look at the URL bar — the long string of hex characters
#              after /users/ is the user ID.
# Example:  JELLYFIN_USER_ID=f47ac10b58cc4372a5670e02b2c3d479
# [REQUIRED]
JELLYFIN_USER_ID=


# ┌─────────────────────────────────────────────────────────────────┐
# │  UNIFI NETWORK                                                  │
# └─────────────────────────────────────────────────────────────────┘
# What:     Credentials for the UniFi Network Controller API.
# How:      1. Log in to your UniFi Controller (usually https://<ip>:8443).
#           2. Go to Settings → Admins & Users.
#           3. Create a NEW local-only admin account:
#              • Username: something like "jarvis-bot"
#              • Role:     "Read Only" (Jarvis only needs to observe)
#           4. Enter the username and password below.
# ⚠  Do NOT reuse your personal admin credentials.
# ⚠  Use a STRONG password (min 12 characters).

# Example:  UNIFI_USERNAME=jarvis-bot
# [REQUIRED]
UNIFI_USERNAME=

# Example:  UNIFI_PASSWORD=S0m3-Str0ng_P4ssw0rd
# Tip:      Avoid these special characters in the password: $ ` \ ! "
#           They can break shell variable parsing.
# [REQUIRED]
UNIFI_PASSWORD=

# What:     The UniFi "site" the emitter connects to.
# How:      Unless you have manually configured multiple sites in
#           your UniFi Controller, leave this as "default".
#           If you have multiple sites, check the URL when you select
#           a site — it looks like .../site/<site-name>/...
# Example:  UNIFI_SITE=default
# [OPTIONAL] (default: default)
UNIFI_SITE=default


# ═══════════════════════════════════════════════════════════════════
#  TROUBLESHOOTING
# ═══════════════════════════════════════════════════════════════════
#
#  "Service X keeps restarting"
#    → You probably left a [REQUIRED] variable empty.
#      Run: docker compose logs <service-name>
#      Look for lines mentioning "missing", "empty", or "invalid".
#
#  "Connection refused" / "timeout"
#    → Make sure the target service (Home Assistant, Jellyfin, UniFi)
#      is actually running and reachable from the Docker network.
#    → Check that you haven't changed the default ports in
#      docker-compose.yml without updating the service URLs.
#
#  "401 Unauthorized" / "403 Forbidden"
#    → Your token or credentials are wrong, expired, or revoked.
#      Regenerate them using the steps above and update .env.
#
#  "I changed .env but nothing happened"
#    → You MUST restart the affected services after editing .env:
#          docker compose up -d
#      Or to restart a single service:
#          docker compose restart <service-name>
#
#  Still stuck?
#    → Open an issue: https://github.com/polaris-owner/Jarvis/issues
# ═══════════════════════════════════════════════════════════════════
